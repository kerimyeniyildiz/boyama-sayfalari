NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Boyama Sayfalari
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=tr-TR

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/boyama_sayfalari

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2a$12$replace_with_bcrypt_hash
SESSION_SECRET=replace-with-a-random-string-at-least-32-characters

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_S3_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-public-r2-or-cdn-domain

# Optional
PLAUSIBLE_DOMAIN=
PLAUSIBLE_SCRIPT_SRC=
REPLICATE_API_TOKEN=
